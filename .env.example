# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, nooit naar frontend/GitHub

# Resend (transactionele e-mail + notificaties bij nieuwe aanmeldingen)
# Nooit een echte sleutel hier of in git zetten — alleen in Vercel invullen.
RESEND_API_KEY=
# Adres waarop de redactie een mail krijgt bij elke nieuwe aanmelding/bericht.
NOTIFICATION_EMAIL=
# Optioneel: overschrijft de standaard-afzender
# ("Low Carb Netherlands <notificaties@mail.lowcarbnetherlands.com>").
RESEND_FROM_EMAIL=

# Site
NEXT_PUBLIC_SITE_URL=https://lowcarbnetherlands.nl

# Analytics (privacyvriendelijk, bv. Plausible)
NEXT_PUBLIC_ANALYTICS_DOMAIN=lowcarbnetherlands.nl
